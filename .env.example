# Server
PORT=3000                                          # HTTP server port
NODE_ENV=development                               # "development" or "production"
APP_NAME=Form Submission API                       # Application display name

# MongoDB
MONGODB_URI=mongodb://localhost:27017/form-submissions  # MongoDB connection string

# SMTP / Email
SMTP_HOST=smtp.gmail.com                           # SMTP server hostname
SMTP_PORT=587                                      # SMTP server port (587 for TLS, 465 for SSL)
SMTP_USER=your-email@gmail.com                     # SMTP username / login
SMTP_PASS=your-app-password                        # SMTP password or app-specific password
SMTP_FROM_NAME=Your App Name                       # Sender display name
SMTP_FROM_EMAIL=noreply@yourapp.com                # Sender email address

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production  # Secret for signing JWTs (keep this safe!)
JWT_EXPIRES_IN=7d                                  # JWT expiry duration (e.g. 7d, 24h, 3600)

# Admin seeder (used on first startup to create the default admin account)
ADMIN_EMAIL=admin@yourapp.com                      # Default admin email
ADMIN_NAME=Admin User                              # Default admin display name
ADMIN_PASSWORD=changeme123                         # Default admin password (change immediately!)

# CORS (optional)
CORS_ORIGIN=http://localhost:3000                  # Allowed CORS origin(s); comma-separated for multiple

# Rate limiting (optional — defaults: 100 requests per 15 minutes)
RATE_LIMIT_MAX=100                                 # Max POST requests per window per IP
RATE_LIMIT_WINDOW_MS=900000                        # Rate limit window in milliseconds (900000 = 15 min)
